# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# ORIGIN — set per environment:
#   Local dev:      ORIGIN="http://localhost:5173"
#   Netlify dev:    ORIGIN="https://order-local.netlify.app"
#   Production:     ORIGIN="https://getorderlocal.com"
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {ORIGIN}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe — per-tenant payments (tenants connect their own Stripe account)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Order Local billing Stripe (your own Stripe account for SaaS subscriptions)
# In dev you can reuse STRIPE_SECRET_KEY; use a separate account in production
ORDERLOCAL_STRIPE_SECRET_KEY="sk_test_..."
ORDERLOCAL_STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudflare R2 (for image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Price IDs — create these products in your Order Local Stripe dashboard
# Plans
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
# Add-ons
STRIPE_PRICE_ADDON_SMS="price_..."
STRIPE_PRICE_ADDON_CUSTOM_DOMAIN="price_..."
STRIPE_PRICE_ADDON_ANALYTICS="price_..."
STRIPE_PRICE_ADDON_LOYALTY="price_..."
STRIPE_PRICE_ADDON_SUBSCRIPTIONS="price_..."
STRIPE_PRICE_ADDON_PROMO_CODES="price_..."
STRIPE_PRICE_ADDON_LOYALTY_ANNUAL="price_..."
STRIPE_PRICE_ADDON_SUBSCRIPTIONS_ANNUAL="price_..."

# Dev auth bypass — skips BetterAuth and populates a fake session/tenant for local UI work.
# NEVER set to "true" in production. Remove or leave commented when not actively using.
# DEV_BYPASS_AUTH=true


# Resend — https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="orders@yourdomain.com"

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
