{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "outputDirectory": ".vercel/output",
  "crons": [
    {
      "path": "/api/cron/materialize",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/billing",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/special-order-expiration",
      "schedule": "0 3 * * *"
    }
  ]
}
